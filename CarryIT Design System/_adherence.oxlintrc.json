{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/web_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Rifton))/i]",
        "message": "Font not provided by the design system. Available: Rifton."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:activeView|onChange|key|ref|className|style|children)$/]",
        "message": "<TopNav> doesn't accept that prop. Declared props: activeView, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopNav'] > JSXAttribute[name.name='activeView'] > Literal[value!=/^(?:vision|jalons|todo)$/]",
        "message": "<TopNav> activeView must be one of 'vision' | 'jalons' | 'todo'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "TopNav": {
        "replaces": []
      }
    },
    "tokens": [
